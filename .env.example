# Port the DiskWatch web UI will be available on (default: 8080)
DISKWATCH_PORT=8080

# Timezone for timestamps — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Optional: webhook URL to receive alert notifications (leave empty to disable)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
